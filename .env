VITE_API_URL="http://localhost:3001"
# Ne pas ré-importer le Google Sheet (données = Firestore / dump)
VITE_DISABLE_SHEET_SYNC=true
# Ne pas appeler Shopify au chargement (produits déjà en PG depuis Firestore)
VITE_DISABLE_SHOPIFY_AUTO_SYNC=true

# Polling nouvelle app (Firestore → PG → API). Min 400 ms.
VITE_POLL_CRITICAL_MS=800
VITE_POLL_STANDARD_MS=1500
VITE_POLL_CALM_MS=4000
VITE_POLL_CONFIG_MS=15000
