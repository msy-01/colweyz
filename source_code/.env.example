# --- Local dev : URL directe du VPS
# VITE_API_URL=http://180.149.197.31

# --- Netlify (HTTPS) : LAISSER VIDE → appels vers /api (proxy Netlify → VPS)
# Ne pas mettre http://180.149.197.31 sur Netlify (Mixed Content bloqué par le navigateur)
VITE_API_URL=

# --- Ou domaine HTTPS sur le VPS
# VITE_API_URL=https://livraison.colweyz.com

# true = PostgreSQL uniquement (colweyz.ddns.net) — pas de bannière Firestore/secours
# false ou absent = hybride Firestore + bascule secours (Netlify / Cloud Run)
# VITE_FORCE_API_MODE=false

# Polling en mode API (ms)
VITE_POLL_CRITICAL_MS=3000
VITE_POLL_STANDARD_MS=5000
VITE_POLL_CALM_MS=8000
VITE_POLL_CONFIG_MS=15000
