# PostgreSQL
DATABASE_URL="postgresql://colweyz:colweyz_local_2026@localhost:5433/colweyz?schema=public"

# JWT
JWT_SECRET="change-me-in-production-colweyz-2026"

# Shopify (moved from client-side AppSettings)
SHOPIFY_DOMAIN="6b9bc5.myshopify.com"
SHOPIFY_ACCESS_TOKEN="shpat_xxxx"

# Claude AI
CLE_API_CLAUDE=""

# Firebase Admin (for sync worker only — Phase 2)
# Chemin absolu vers la clé JSON (Firebase Console → Comptes de service)
GOOGLE_APPLICATION_CREDENTIALS="/chemin/vers/votre-firebase-adminsdk-xxxxx.json"
FIREBASE_DATABASE_ID="ai-studio-fc447c3d-4c26-4889-a3bd-ef7015720531"

# Sync dual-app (ancienne app Firestore + nouvelle app PostgreSQL)
# Forward seul = Firestore → PG (ne modifie pas Firestore)
# Reverse = PG → Firestore : garder false tant que PG n'est pas validé (risque pour l'ancienne app)
SYNC_ENABLED=true
SYNC_REVERSE_ENABLED=false
SYNC_REVERSE_POLL_MS=3000
SYNC_REVERSE_BATCH_SIZE=200
SYNC_REVERSE_DELETE_EVERY=10
# Liste optionnelle (CSV) pour ne pousser que certaines collections ; vide = toutes
# Exemple: orders,drivers,zones
SYNC_REVERSE_COLLECTIONS=
# true = inclure shopifyAccessToken dans settings/global (déconseillé sauf besoin explicite)
SYNC_REVERSE_PUSH_SHOPIFY_TOKEN=false

# Server
PORT=3001
NODE_ENV=development
